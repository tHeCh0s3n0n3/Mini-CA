{
  "ConnectionStrings": {
    "SQLiteConnection": "Data Source=/app/data/db.sqlite;Cache=Shared;",
    "IdentityConnection": "Data Source=/app/data/identity.sqlite;Cache=Shared;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": { "path": "/app/logs/Log.txt", "rollingInterval": "Day" }
      }
    ]
  },
  "AllowedHosts": "*",
  "Site": {
    "LogoUrl": ""
  },
  "Authentik": {
    "Authority": "https://authentik.company.com/application/o/minica/",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "CACert": {
    "CertFilePath": "/app/secrets/ca.crt"
  },
  "Acme": {
    "DirectoryHostname": "",
    "DirectoryPath": "/acme/directory"
  }
}
