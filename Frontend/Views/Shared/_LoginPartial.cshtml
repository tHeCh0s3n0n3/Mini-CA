<ul class="navbar-nav">
@if (User?.Identity?.IsAuthenticated == true)
{
    var friendlyName = User.Identity.Name;

    <li class="nav-item">
        <span class="nav-link text-dark">Hello @friendlyName!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-controller="Home" asp-action="LogOut">
            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Home" asp-action="LogIn">Login</a>
    </li>
}
</ul>
