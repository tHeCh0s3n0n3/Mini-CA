                    <label asp-for="PurposeAll" class="form-check-label"></label>
                    @if (isCSR_PurposeAll) { <input type="hidden" asp-for="PurposeAll" /> <span class="badge bg-info text-dark ms-1" title="Requested in CSR">CSR</span> }
                </div>
