@model IEnumerable<Backend.Models.CSRIndexViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create New</a>
    <a asp-action="Upload" class="btn btn-outline-primary ms-2"><i class="bi bi-upload"></i> Upload CSR</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CountryCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommonName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FileName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FileSize)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SubmittedOn)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model is not null) {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.CountryCode)
                    </td>
                    <td>
                        <strong>@Html.DisplayFor(modelItem => item.CommonName)</strong><br />
                        @foreach (var san in item.AlternateNames)
                        {
                            <small class="text-muted d-block">@san</small>
                        }
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.FileName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.FileSize)
                    </td>
                    <td>
                        @item.SubmittedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                    </td>
                    <td>
                        <div class="btn-group me-2">
                            @if (!string.IsNullOrEmpty(item.EncryptedPrivateKey))
                            {
                                <a asp-action="DownloadKey" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Download Private Key">
                                    <i class="bi bi-key"></i>
                                </a>
                            }
                            @if (item.IsSigned && item.SignedCSRId is not null)
                            {
                                <a asp-action="DownloadCertificate"
                                 asp-route-id="@item.SignedCSRId"
                                        class="btn btn-success"
                                        title="Download Certificate">
                                    <i class="bi bi-download"></i>
                                </a>
                            }
                            else
                            {
                                <a asp-action="Process"
                                 asp-route-id="@item.Id"
                                        class="btn btn-secondary" title="Process">
                                    <i class="bi bi-check-lg"></i>
                                </a>
                            }
                        </div>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary" title="Details"><i class="bi bi-info-circle"></i></a>
                        <a asp-action="Create" asp-route-copyId="@item.Id" class="btn btn-outline-info" title="Copy / Renew CSR"><i class="bi bi-copy"></i></a>
                        <form asp-action="Delete" method="POST" asp-route-id="@item.Id" 
                               onclick="return confirm('Are you sure you want to delete this?')"
                              style="display:inline">
                          <button type="submit" class="btn btn-danger" title="Delete"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
