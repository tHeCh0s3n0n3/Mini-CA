@model IEnumerable<DAL.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<h1>Issuance Audit Logs</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Timestamp</th>
            <th>Actor</th>
            <th>Action</th>
            <th>Subject</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
            <td>@item.Actor</td>
            <td><span class="badge bg-info text-dark">@item.Action</span></td>
            <td>@item.Subject</td>
            <td><small>@item.Details</small></td>
        </tr>
}
    </tbody>
</table>
