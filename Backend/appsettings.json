{
  "ConnectionStrings": {
    "SQLiteConnection": "Data Source=/app/data/db.sqlite;Mode=ReadWrite;Cache=Shared;",
    "IdentityConnection": "Data Source=/app/data/identity.sqlite;Mode=ReadWrite;Cache=Shared;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Authentik": {
    "Authority": "https://authentik.company.com/application/o/minica/",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "Acme": {
    "MaxOrdersPerMinute": 10,
    "MasterKeyPath": "/app/secrets/master.key"
  },
  "CACert": {
    "CertFilePath": "/app/secrets/ca.crt",
    "CertKeyFilePath": "/app/secrets/ca.key",
    "CertKeyPasswordFilePath": "/app/secrets/ca.key.passwd"
  }
}
